# Default: let Git normalize line endings for tracked text on commit.
* text=auto

# Parser test fixtures are byte-exact: span assertions in tests/parser_tests.rs compare
# &source[start_byte..end_byte] to expected text, so newline bytes must NOT be rewritten.
# Pin LF fixtures to LF and the CRLF fixture to CRLF regardless of platform / core.autocrlf.
tests/fixtures/python/*.py    -text
tests/fixtures/python/crlf_function.py    -text eol=crlf
