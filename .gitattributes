# Default: let Git normalize line endings for tracked text on commit.
* text=auto

# Test fixtures are compared byte-exact: parser span assertions slice
# &source[start_byte..end_byte] and compare to expected LF text (tests/parser_{tests,go_tests,
# ts_tests}.rs); the formatter golden tests compare serializer output to committed files. Newline
# bytes must NOT be rewritten on checkout, or Windows CRLF conversion breaks the asserts. Pin EVERY
# fixture to LF regardless of platform / core.autocrlf (the blobs are committed LF)...
tests/fixtures/**    -text
# ...except the ONE intentional CRLF fixture (the parser CRLF-preservation test, which asserts the
# parser keeps \r\n). More specific + last ⇒ this rule wins for that single file.
tests/fixtures/python/crlf_function.py    -text eol=crlf
